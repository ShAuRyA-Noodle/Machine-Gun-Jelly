# Machine Gun Jelly — copy to .env.local and fill in.

# === LLM providers ===
GROQ_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
OPENROUTER_API_KEY=

# === Search ===
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# === Storage / DB ===
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# === Auth + actions ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# === Email notifications ===
RESEND_API_KEY=

# === Background jobs ===
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# === Browser automation (optional, else local Playwright) ===
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# === Critic agent ===
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=machine-gun-jelly/0.1

# === Maps ===
MAPBOX_TOKEN=

# === Misc ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
